# VOIDER — Environment Configuration
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#   # then edit .env

# ── LLM Provider ──────────────────────────────────────────────
# Options: ollama | groq | openai | gemini | xai
VOIDER_PROVIDER=ollama

# ── API Key (only required for cloud providers) ───────────────
# Groq:    https://console.groq.com/keys
# OpenAI:  https://platform.openai.com/api-keys
# Gemini:  https://aistudio.google.com/app/apikey
# xAI:     https://console.x.ai/
VOIDER_API_KEY=

# ── Model Override (leave empty to use provider default) ──────
# Ollama:  llama3.2, mistral, phi3, gemma2 ...
# Groq:    llama-3.3-70b-versatile, mixtral-8x7b-32768 ...
# OpenAI:  gpt-4o, gpt-4o-mini, gpt-3.5-turbo ...
# Gemini:  gemini-1.5-flash, gemini-1.5-pro ...
# xAI:     grok-beta ...
VOIDER_MODEL=

# ── Port ──────────────────────────────────────────────────────
VOIDER_PORT=8000

# ── Ollama Model (pulled automatically) ───────────────────────
# Only relevant when VOIDER_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
